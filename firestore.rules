rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isExperimentAuthor(experimentId) {
      return get(/databases/$(database)/documents/play_experiments/$(experimentId)).data.authorId == request.auth.uid;
    }

    match /users/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }

    match /routes/{id} {
      allow read: if true;
      allow write: if request.auth != null && request.auth.token.role == "admin";
    }

    match /modules/{id} {
      allow read: if true;
      allow write: if request.auth != null && request.auth.token.role == "admin";
    }

    match /exercises/{id} {
      allow read: if true;
      allow write: if request.auth != null && request.auth.token.role == "admin";
    }

    match /projects_creativo/{id} {
      allow read, update, delete: if request.auth != null && request.auth.uid == resource.data.userId;
      allow create: if request.auth != null && request.auth.uid == request.resource.data.userId;
    }

    match /progress/{id} {
      allow read, update, delete: if request.auth != null && request.auth.uid == resource.data.userId;
      allow create: if request.auth != null && request.auth.uid == request.resource.data.userId;
    }

    match /play_experiments/{id} {
      allow get, list: if true;
      allow create: if request.auth != null && request.auth.uid == request.resource.data.authorId;
      allow update, delete: if request.auth != null && request.auth.uid == resource.data.authorId;
    }

    match /play_iterations/{iterationId} {
      allow read: if true;
      allow create: if request.auth != null && isExperimentAuthor(request.resource.data.experimentId);
      allow update, delete: if request.auth != null && isExperimentAuthor(resource.data.experimentId);
    }

    match /play_challenges/{id} {
      allow read: if true;
      allow write: if request.auth != null && request.auth.token.role == "admin";
    }

    match /play_to_vitrina/{id} {
      allow read: if true;
      allow write: if request.auth != null && request.auth.token.role == "admin";
    }
  }
}
